{
  "name": "forex-backend",
  "version": "2.0.0",
  "description": "Professional backend API for the Forex Trading App",
  "main": "src/index.js",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "prestart": "node scripts/ensurePrismaClient.js",
    "start": "node src/index.js",
    "predev": "node scripts/ensurePrismaClient.js",
    "dev": "node --watch src/index.js",
    "lint": "eslint src",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:reset": "prisma migrate reset",
    "db:seed": "node prisma/seed.js",
    "seed": "node prisma/seed.js",
    "test": "node --test src/**/*.test.js"
  },
  "dependencies": {
    "@arcjet/inspect": "^1.1.0",
    "@arcjet/node": "^1.1.0",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "expo-server-sdk": "^6.0.0",
    "express": "^4.19.2",
    "express-async-errors": "^3.1.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.9.3",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.10.1",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "stripe": "^20.3.1",
    "uuid": "^9.0.1",
    "ws": "^8.18.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.3.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prisma": "^7.4.1",
    "supertest": "^7.2.2",
    "typescript": "^5.9.3"
  }
}

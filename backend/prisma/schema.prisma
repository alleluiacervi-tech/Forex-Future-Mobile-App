generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderSide {
  buy
  sell
}

enum OrderStatus {
  filled
  pending
  canceled
}

enum TransactionType {
  trade
  deposit
  withdrawal
}

enum RiskLevel {
  conservative
  moderate
  aggressive
}

model User {
  id            String      @id @default(uuid())
  name          String
  email         String      @unique
  passwordHash  String
  emailVerified Boolean     @default(false)
  emailVerifiedAt DateTime?
  isActive      Boolean     @default(true)
  isAdmin       Boolean     @default(false)
  lastLogin     DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  baseCurrency  String      @default("USD")
  riskLevel     RiskLevel   @default(moderate)
  notifications Boolean     @default(true)
  trialActive   Boolean     @default(false)
  trialStartedAt DateTime?
  account       Account?
  positions     Position[]
  orders        Order[]
  transactions  Transaction[]
  watchlist     Watchlist?
  recommendations Recommendation[]
  paymentMethods PaymentMethod[]
  subscriptions Subscription[]
  paymentEvents PaymentEvent[]
  trialFingerprints TrialFingerprint[]
  otps          Otp[]
  pushTokens    PushToken[]
  userAlerts    UserAlert[]
  preferences   UserPreference?
  refreshTokens RefreshToken[]
  notificationRecords Notification[]
}

model Account {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String   @unique
  balance    Float    @default(100000)
  equity     Float    @default(100000)
  marginUsed Float    @default(0)
  currency   String   @default("USD")
  updatedAt  DateTime @updatedAt
}

model Position {
  id           String   @id @default(uuid())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  pair         String
  side         OrderSide
  units        Float
  entryPrice   Float
  openTime     DateTime @default(now())
  unrealizedPnl Float   @default(0)

  @@index([userId])
  @@index([userId, pair])
}

model Order {
  id        String      @id @default(uuid())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  pair      String
  side      OrderSide
  units     Float
  price     Float
  status    OrderStatus @default(filled)
  createdAt DateTime    @default(now())

  @@index([userId])
  @@index([userId, status, createdAt])
}

model Transaction {
  id        String          @id @default(uuid())
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  type      TransactionType
  pair      String?
  side      OrderSide?
  units     Float?
  price     Float?
  timestamp DateTime        @default(now())

  @@index([userId])
  @@index([userId, type, timestamp])
}

model Watchlist {
  id     String   @id @default(uuid())
  user   User     @relation(fields: [userId], references: [id])
  userId String   @unique
  pairs  String[]
}

// OTPs generated for verification and sensitive actions.
model Otp {
  id         String   @id @default(uuid())
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId     String?
  email      String?
  purpose    String   // e.g. "email_verification", "password_reset", "login", "email_change", "payment_update", "account_deletion"
  otpHash    String
  expiresAt  DateTime
  attempts   Int      @default(0)
  used       Boolean  @default(false)
  ip         String?
  deviceInfo String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, purpose])
  @@index([email, purpose])
  @@index([expiresAt])
}

model Recommendation {
  id               String   @id @default(uuid())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId           String
  pair             String
  action           String
  confidence       Float
  entry            Float?
  stopLoss         Float?
  takeProfit1      Float?
  takeProfit2      Float?
  riskReward       String?
  positionSizeLots Float?
  rationale        String
  createdAt        DateTime @default(now())
}

model PaymentMethod {
  id                String   @id @default(uuid())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId            String
  provider          String   @default("card")
  fingerprint       String?
  brand             String?
  last4             String
  expMonth          Int
  expYear           Int
  holderName        String?
  billingPostalCode String?
  isDefault         Boolean  @default(false)
  token             String?  @unique
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([fingerprint])
}

model MarketCandle {
  id          String   @id @default(uuid())
  pair        String
  interval    String
  bucketStart DateTime
  open        Float
  high        Float
  low         Float
  close       Float
  volume      Float    @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([pair, interval, bucketStart])
  @@index([pair, interval, bucketStart])
}

model MarketAlert {
  id            String   @id @default(uuid())
  pair          String
  windowMinutes Int
  fromPrice     Float
  toPrice       Float
  changePercent Float
  severity      String
  currentPrice  Float?
  direction     String?
  velocity      Json?
  confidence    Json?
  levels        Json?
  triggeredAt   DateTime @default(now())
  createdAt     DateTime @default(now())

  @@index([pair, triggeredAt])
}

model Subscription {
  id                   Int            @id @default(autoincrement())
  userId               String?        @map("user_id")
  user                 User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  plan                 String         @db.VarChar(20)
  status               String         @db.VarChar(20)
  amount               Decimal        @db.Decimal(10, 2)
  currency             String         @default("USD") @db.VarChar(3)
  trialStart           DateTime?      @map("trial_start")
  trialEnd             DateTime?      @map("trial_end")
  currentPeriodEnd     DateTime?      @map("current_period_end")
  gracePeriodEnd       DateTime?      @map("grace_period_end")
  cancelReason         String?        @map("cancel_reason")
  cardLast4            String?        @map("card_last4") @db.VarChar(4)
  cardFingerprint      String?        @map("card_fingerprint")
  payerId              String?        @map("payer_id")
  paypalSubscriptionId String?        @unique @map("paypal_subscription_id")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  paymentEvents        PaymentEvent[] @relation("SubscriptionPaymentEvents")

  @@index([userId], map: "subscriptions_user_id_idx")
  @@index([status], map: "subscriptions_status_idx")
  @@index([cardFingerprint], map: "subscriptions_card_fingerprint_idx")
  @@index([payerId], map: "subscriptions_payer_id_idx")
  @@map("subscriptions")
}

model PaymentEvent {
  id                   Int           @id @default(autoincrement())
  userId               String?       @map("user_id")
  user                 User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  subscriptionId       Int?          @map("subscription_id")
  subscription         Subscription? @relation("SubscriptionPaymentEvents", fields: [subscriptionId], references: [id], onDelete: SetNull)
  eventType            String        @db.VarChar(50) @map("event_type")
  paypalEventId        String?       @unique @map("paypal_event_id")
  paypalSubscriptionId String?       @map("paypal_subscription_id")
  amount               Decimal?      @db.Decimal(10, 2)
  status               String?       @db.VarChar(20)
  failureReason        String?       @map("failure_reason")
  rawEvent             Json          @map("raw_event")
  createdAt            DateTime      @default(now()) @map("created_at")

  @@index([userId], map: "payment_events_user_id_idx")
  @@index([subscriptionId], map: "payment_events_subscription_id_idx")
  @@index([paypalSubscriptionId], map: "payment_events_paypal_subscription_id_idx")
  @@map("payment_events")
}

model TrialFingerprint {
  id              Int      @id @default(autoincrement())
  cardFingerprint String   @unique @map("card_fingerprint")
  userId          String?  @map("user_id")
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  usedAt          DateTime @default(now()) @map("used_at")

  @@index([userId], map: "trial_fingerprints_user_id_idx")
  @@map("trial_fingerprints")
}

// ── New models ──────────────────────────────────────────────────────────────

model RefreshToken {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revoked   Boolean  @default(false)
  ip        String?
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model PushToken {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  token     String   @unique
  platform  String   // "ios" | "android" | "web"
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Notification {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  title     String
  body      String
  type      String   // "alert", "trade", "system", "promo"
  read      Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}

model UserPreference {
  id                 String  @id @default(uuid())
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId             String  @unique
  baseCurrency       String  @default("USD")
  riskLevel          RiskLevel @default(moderate)
  notifications      Boolean @default(true)
  emailAlerts        Boolean @default(true)
  pushAlerts         Boolean @default(true)
  theme              String  @default("system") // "light" | "dark" | "system"
  language           String  @default("en")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Alert {
  id          String      @id @default(uuid())
  pair        String
  condition   String      // "price_above", "price_below", "pct_change"
  threshold   Float
  message     String?
  active      Boolean     @default(true)
  triggeredAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  userAlerts  UserAlert[]

  @@index([pair, active])
}

model UserAlert {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  alert     Alert    @relation(fields: [alertId], references: [id], onDelete: Cascade)
  alertId   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, alertId])
  @@index([userId])
  @@index([alertId])
}

model AlertOutcome {
  id         String    @id @default(uuid())
  alertId    String?
  pair       String
  direction  String
  entryPrice Float
  slPrice    Float
  tp1Price   Float
  tp2Price   Float
  tp3Price   Float
  outcome    String?   // "SL_HIT", "TP1_HIT", "TP2_HIT", "TP3_HIT", "EXPIRED"
  exitPrice  Float?
  exitedAt   DateTime?
  pnlPips    Float?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([pair, outcome])
  @@index([createdAt])
}

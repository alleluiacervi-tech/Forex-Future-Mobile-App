{
  "expo": {
    "name": "Forex Trading App",
    "slug": "forextradingapp",
    "scheme": "forexapp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/image.png",
    "userInterfaceStyle": "light",
    "updates": {
      "enabled": false
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.forextradingapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/image.png",
        "backgroundColor": "#0f0f1e"
      },
      "package": "com.forextradingapp"
    },
    "web": {},
    "plugins": [
      "expo-web-browser",
      "@sentry/react-native"
    ]
  }
}

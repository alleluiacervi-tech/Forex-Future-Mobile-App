# ─── Database ───────────────────────────────────────────
DATABASE_URL=postgresql://user:password@your-neon-host.neon.tech/dbname?sslmode=require

# ─── JWT ────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=2h

# ─── PayPal ─────────────────────────────────────────────
# Get credentials from https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_paypal_client_id
PAYPAL_SECRET=your_paypal_secret_key
PAYPAL_WEBHOOK_ID=your_webhook_id

# PayPal subscription plan IDs (create in PayPal dashboard)
PAYPAL_PLAN_MONTHLY=P-XXXXXXXXXX
PAYPAL_PLAN_QUARTERLY=P-XXXXXXXXXX
PAYPAL_PLAN_ANNUAL=P-XXXXXXXXXX

# Return URLs after PayPal approval/cancellation
PAYPAL_RETURN_URL=forexapp://billing/success
PAYPAL_CANCEL_URL=forexapp://billing/cancel

# Optional: override base URL (defaults to sandbox in dev, live in production)
# PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# ─── Arcjet ─────────────────────────────────────────────
ARCJET_KEY=your_arcjet_key
# ARCJET_ENABLED=true
# ARCJET_MODE=DRY_RUN

# ─── Email (Resend) ────────────────────────────────────
RESEND_API_KEY=your_resend_api_key

# ─── Market Data ────────────────────────────────────────
TWELVEDATA_API_KEY=your_twelvedata_key

# ─── Server ─────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# TRUST_PROXY=false
# DATABASE_REQUIRED=false
